# =============================================================================
# LAMP Stack - Example Environment Configuration
# Copy this file to .env and edit the values to match your setup
# Do NOT commit your .env file to GitHub - it contains passwords
# =============================================================================

APPDATA_PATH=/mnt/user/appdata/LampStack
WEBSERVER_IP=192.168.0.x
LAMP_SUBNET=172.21.0.0/24
TZ=Europe/London
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=lampstack
MYSQL_USER=lampstack
MYSQL_PASSWORD=your_password_here
HTTP_PORT=80
HTTPS_PORT=443
PMA_PORT=8080
