# =============================================================================
# LAMP Stack - Site Manager Environment Configuration
# Place the filled-in version at:
#   /mnt/user/VM/Dockers/LampStack/websites/.env
#
# This example file is safe to commit to git.
# The real .env is excluded via .gitignore and should never be committed.
# =============================================================================

# IP address this web server is accessible at on your local network
# New sites created via the Site Manager will point to this IP in Pi-hole
SERVER_IP=192.168.0.23

# Pi-hole host (no trailing slash)
PIHOLE_HOST=http://192.168.0.6

# Pi-hole v6 app password (Settings -> API -> App password)
PIHOLE_API_KEY=your_api_key_here
