# =============================================================================
# LAMP Stack - Git Ignore Rules
# Rename this file to .gitignore
# =============================================================================

# Never commit the .env file - it contains passwords
.env

# Renamed dotfiles - txt versions no longer needed after setup.bat has run
*.txt

# Setup batch file - not needed in the repo, only for local first-time setup
*.bat

# Windows thumbnail cache
Thumbs.db

# MacOS metadata
.DS_Store

# Editor directories
.vscode/
.idea/

# Old Files Folder
Old/
